{
  "name": "PortScope Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",

  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y lsof net-tools iproute2 && npm install && npm --prefix client install",

  "postAttachCommand": "npm run dev",

  "forwardPorts": [4000, 5173],

  "portsAttributes": {
    "4000": {
      "label": "PortScope API",
      "onAutoForward": "silent"
    },
    "5173": {
      "label": "PortScope Frontend",
      "onAutoForward": "openBrowser"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}

